# Copy this file to `.env` and fill in your own values. `.env` is gitignored.

# Weights & Biases (https://wandb.ai/) — required for experiment logging.
WANDB_API_KEY=your_wandb_api_key_here
# WANDB_MODE=online            # online | offline | disabled
# WANDB_ENTITY=your_username   # username or team

# Hugging Face (https://huggingface.co/) — used for some pretrained model downloads.
HUGGING_KEY=your_huggingface_token_here

# Optional: HPC submission (used by experiments/*/run_*.py for remote runs on Slurm).
# Leave unset to run experiments locally only.
# HPC_USERNAME=your_user
# HPC_HOST=your_user@login.your-cluster.example
# HPC_SSH_KEY=/path/to/your/private/key
# HPC_PASSWORD=                # optional, only if you use sshpass-based submission
